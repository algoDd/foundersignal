# FounderSignal — Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# CORE (Required)
# =============================================================================

# Google Gemini API Key — get from https://aistudio.google.com/
GEMINI_API_KEY=

# Tavily API Key — get from https://app.tavily.com/
TAVILY_API_KEY=

# =============================================================================
# PARTNER INTEGRATIONS (Optional — graceful fallback if missing)
# =============================================================================

# Hera Video API Key — get from https://hera.video/api or contact team
HERA_API_KEY=

# Peec AI API Key — get from https://app.peec.ai/api-keys
PEEC_API_KEY=



# =============================================================================
# SERVER CONFIG
# =============================================================================

# FastAPI server
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=info

# LLM Provider (default: gemini) — future: openai, anthropic
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview

# Supabase Config
SUPABASE_URL=
SUPABASE_KEY=
SUPABAS_SECRET_KEY=
DB_PASS=
